# Copy this file to `.env` for local development (`.env` is git-ignored).
# In production (Azure App Service) these are set as Application Settings instead.

# Local development
DEBUG=True

# Production only — leave unset locally:
# SECRET_KEY=<generate a long random string for production>
# DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DBNAME   (unset = local SQLite)
# ALLOWED_HOSTS=yourapp.azurewebsites.net
# SENDGRID_API_KEY=<from your SendGrid account>            (Milestone 5)
# DEFAULT_FROM_EMAIL="ClassProject <no-reply@yourdomain.com>"  (verified SendGrid sender)
# ADMIN_EMAIL=instructor@yourdomain.com   (admin notifications: new users/projects; unset = off)
# SITE_URL=https://yourapp.azurewebsites.net   (links inside notification emails)
